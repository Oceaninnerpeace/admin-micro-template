{
  "name": "@admin-template/admin-sider",
  "version": "1.0.0",
  "description": "后台管理模板 — 权限树侧栏（Ant Design Vue）",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./style.css": "./src/style/sidebar.css"
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "vue-tsc -p tsconfig.build.json --noEmit && vite build",
    "prepublishOnly": "pnpm run build && node ./scripts/prepare-publish-exports.mjs",
    "postpublish": "node ./scripts/restore-dev-exports.mjs"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "ant-design-vue": "^4.2.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "ant-design-vue": "^4.2.6",
    "typescript": "~5.7.2",
    "vite": "^6.0.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
