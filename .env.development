# 应用展示名（顶栏/工作台）
VITE_APP_TITLE=后台管理系统模板

# Qiankun：须与基座 portal-apps 中 name、activeRule 前缀一致
VITE_QIANKUN_APP_NAME=admin-template
VITE_MICRO_BASE_PATH=/micro/app
VITE_DEV_PORT=5180

# API：开发环境走 Vite 代理
VITE_API_BASE_URL=/api
VITE_QIANKUN_DEV_ORIGIN=http://localhost:5180
VITE_PROXY_TARGET=http://127.0.0.1:8080

# 无后端时 true：登录走本地 mock
VITE_USE_MOCK_AUTH=false
# VITE_AUTH_CAPTCHA_PATH=/auth/captcha
